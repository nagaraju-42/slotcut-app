{
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_API_URL",
      "description": "Backend API URL",
      "value": "https://slotcut-backend.railway.app/api"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
