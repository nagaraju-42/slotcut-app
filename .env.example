# Frontend Environment Variables Example
# Copy this file to .env.local and update with your actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# JWT Storage (browser localStorage key prefix)
NEXT_PUBLIC_APP_NAME=slotcut

# Feature Flags
NEXT_PUBLIC_ENABLE_QUEUE_TRACKING=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=true

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Deployment URLs (set during deployment)
# For Vercel deployment: https://your-app.vercel.app/api
